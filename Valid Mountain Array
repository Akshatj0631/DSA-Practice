class Solution {
    public boolean validMountainArray(int[] arr) {
        int n=arr.length;
        if(n<3) return false;
        int l=0;
        
        while(l<n-1 && arr[l]<arr[l+1])
            {
               l++;
            }
        if(l==0||l==n-1)return false;
        while(l+1<n && arr[l]>arr[l+1])
            {
                l++;
            }
        return l==n-1;
    }
}
